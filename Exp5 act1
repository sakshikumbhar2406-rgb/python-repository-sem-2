#Dictionary storing book names and prices
books = {
    "Maths": 250, 
     "Science": 300,
    "English": 200
}

#Updating price of a book
books["Science"] = 350

print("Updated Book Prices:")
for book, price in books.items():
    print(book,":", price)

Output:-
Updated Book Prices:
Maths : 250
Science : 350
English : 200
