        "items = [\"Apple\", \"Banana\", \"Orange\"]\n",
        "copies = 3\n",
        "\n",
        "for i in range(copies):\n",
        "  print(f\"Receipt copy{i+1}:\")\n",
        "  for j, item in enumerate(items, start=1):\n",
        "    print(f\"Item {j}: {item}\")\n",
        "print()"
